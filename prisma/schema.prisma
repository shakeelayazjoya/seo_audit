generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String              @id @default(cuid())
  email        String              @unique
  passwordHash String?
  name         String?
  image        String?
  role         String              @default("user")
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  audits       Audit[]
  sessions     Session[]
  leads        Lead[]
  requests     CommercialRequest[]
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

model Audit {
  id            String              @id
  domain        String
  status        String              @default("queued")
  overallScore  Int                 @default(0)
  technical     String?
  onPage        String?
  performance   String?
  cro           String?
  localSeo      String?
  aiSeo         String?
  schema        String?
  rawModules    String?
  errorMessage  String?
  isPartial     Boolean             @default(false)
  partialReason String?
  crawlPageCount Int                @default(0)
  crawlErrorCount Int               @default(0)
  userId        String?
  user          User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  job           AuditJob?
  requests      CommercialRequest[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([domain, createdAt])
  @@index([status, createdAt])
}

model AuditJob {
  id              String   @id @default(cuid())
  auditId         String   @unique
  audit           Audit    @relation(fields: [auditId], references: [id], onDelete: Cascade)
  domain          String
  status          String   @default("queued")
  priority        Int      @default(0)
  attempts        Int      @default(0)
  maxAttempts     Int      @default(3)
  workerId        String?
  lockedAt        DateTime?
  startedAt       DateTime?
  finishedAt      DateTime?
  lastHeartbeatAt DateTime?
  errorMessage    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status, priority, createdAt])
  @@index([workerId])
}

model Lead {
  id        String   @id @default(cuid())
  email     String
  domain    String?
  auditId   String?
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  source    String   @default("pdf_gate")
  status    String   @default("captured")
  createdAt DateTime @default(now())

  @@index([email, createdAt])
}

model RateLimitBucket {
  id          String   @id @default(cuid())
  key         String
  action      String
  windowStart DateTime
  expiresAt   DateTime
  count       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([key, action, windowStart])
  @@index([expiresAt])
}

model AppEvent {
  id        String   @id @default(cuid())
  level     String
  type      String
  message   String
  context   Json?
  createdAt DateTime @default(now())

  @@index([type, createdAt])
  @@index([level, createdAt])
}

model CommercialRequest {
  id          String   @id @default(cuid())
  type        String
  provider    String
  status      String   @default("created")
  email       String?
  domain      String?
  auditId     String?
  audit       Audit?   @relation(fields: [auditId], references: [id], onDelete: SetNull)
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  externalId  String?
  externalUrl String?
  payload     Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type, createdAt])
  @@index([provider, status, createdAt])
}
